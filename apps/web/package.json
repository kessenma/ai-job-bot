{
  "name": "web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun run cleanup && bun --bun vite dev --port 3000",
    "build": "bun --bun vite build",
    "preview": "vite preview",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "cleanup": "lsof -ti:3000 | xargs kill -9 2>/dev/null; pkill -f 'bun.*vite' 2>/dev/null; pkill -f 'vite.*dev' 2>/dev/null; rm -rf node_modules/.vite/deps_temp_* 2>/dev/null; echo 'Cleanup complete'"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@job-app-bot/db": "workspace:*",
    "@job-app-bot/shared": "workspace:*",
    "@phosphor-icons/react": "^2.1.7",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.9.10",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-router-devtools": "^1.166.2",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "googleapis": "^171.4.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.11.0",
    "motion": "^12.23.12",
    "ogl": "^1.0.11",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "^0.5.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "shadcn": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
